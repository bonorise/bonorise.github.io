---
import { SEO } from "astro-seo";

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  pubDate?: Date;
}

const { title, description, image, article = false, pubDate } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- 预加载字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-1467729400140451">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1467729400140451" crossorigin="anonymous"></script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-90KFYRQSGN"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-90KFYRQSGN');
    </script>

    <SEO
      title={title}
      titleTemplate="%s | liubo.im"
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title: title,
          type: article ? "article" : "website",
          image: image || "https://liubo.im/og-image.png",
          url: canonicalURL.toString()
        },
        optional: {
          siteName: "liubo.im",
          description: description,
          locale: "zh_CN"
        },
        image: {
          alt: title,
          width: 1200,
          height: 630
        },
        ...(article && pubDate && {
          article: {
            publishedTime: pubDate.toISOString()
          }
        })
      }}
      twitter={{
        card: "summary_large_image",
        title: title,
        description: description,
        image: image || "https://liubo.im/og-image.png"
      }}
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  /* ===== CSS 变量 ===== */
  :root {
    /* 主色调 - 深墨绿 */
    --color-primary: #2d5a4a;
    --color-primary-light: #3d7a64;
    --color-primary-dark: #1a3d33;

    /* 背景色 - 暖调米白 */
    --color-bg: #f8f6f1;
    --color-bg-white: #ffffff;
    --color-bg-card: #ffffff;

    /* 文字色 */
    --color-text: #2c2c2c;
    --color-text-light: #5a5a5a;
    --color-text-muted: #888888;

    /* 边框色 */
    --color-border: #e8e4df;
    --color-border-light: #f0ede8;

    /* 阴影 */
    --shadow-sm: 0 1px 2px rgba(45, 90, 74, 0.06);
    --shadow-md: 0 4px 12px rgba(45, 90, 74, 0.08);
    --shadow-lg: 0 8px 24px rgba(45, 90, 74, 0.12);

    /* 圆角 */
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;

    /* 间距 */
    --space-xs: 0.5rem;
    --space-sm: 0.75rem;
    --space-md: 1rem;
    --space-lg: 1.5rem;
    --space-xl: 2rem;
    --space-2xl: 3rem;

    /* 字体 */
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;

    /* 动效 */
    --transition-fast: 150ms ease;
    --transition-base: 250ms ease;
    --transition-slow: 400ms ease;
  }

  /* ===== 基础重置 ===== */
  *, *::before, *::after {
    box-sizing: border-box;
  }

  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    padding: 0;
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    background-color: var(--color-bg);
    min-height: 100vh;
  }

  /* ===== 链接 ===== */
  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  a:hover {
    color: var(--color-primary-light);
  }

  /* ===== 标题 ===== */
  h1, h2, h3, h4, h5, h6 {
    margin-top: 0;
    line-height: 1.3;
    font-weight: 600;
  }

  h1 { font-size: 2rem; }
  h2 { font-size: 1.5rem; }
  h3 { font-size: 1.25rem; }

  /* ===== 段落 ===== */
  p {
    margin-top: 0;
    margin-bottom: 1.25rem;
  }

  /* ===== 列表 ===== */
  ul, ol {
    margin-top: 0;
    padding-left: 1.5rem;
  }

  /* ===== 代码块 ===== */
  code, pre {
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Fira Mono', 'Droid Sans Mono', 'Source Code Pro', monospace;
    font-size: 0.875em;
  }

  code {
    background: var(--color-bg);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  pre {
    background: #1a1a1a;
    color: #e5e5e5;
    padding: 1.25rem;
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  pre code {
    background: none;
    padding: 0;
    border: none;
    color: inherit;
  }

  /* ===== 引用 ===== */
  blockquote {
    margin: 1.5rem 0;
    padding: 0.75rem 0 0.75rem 1.25rem;
    border-left: 4px solid var(--color-primary);
    background: var(--color-bg);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--color-text-light);
  }

  /* ===== 图片 ===== */
  img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
  }

  /* ===== 表格 ===== */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  th, td {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  th {
    background: var(--color-bg);
    font-weight: 600;
  }

  /* ===== 动效类 ===== */
  .fade-in {
    animation: fadeIn var(--transition-slow) ease forwards;
    opacity: 0;
    transform: translateY(12px);
  }

  .fade-in.delay-1 { animation-delay: 80ms; }
  .fade-in.delay-2 { animation-delay: 160ms; }
  .fade-in.delay-3 { animation-delay: 240ms; }
  .fade-in.delay-4 { animation-delay: 320ms; }
  .fade-in.delay-5 { animation-delay: 400ms; }

  @keyframes fadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
