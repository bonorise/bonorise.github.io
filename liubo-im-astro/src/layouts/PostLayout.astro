---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category?: string;
  image?: string;
}

const { title, description, pubDate, category, image } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  article={true}
  pubDate={pubDate}
>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
        {category && <span class="category">· {category}</span>}
      </div>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>

  <style>
    .post {
      max-width: 720px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .post-header {
      margin-bottom: 3rem;
      text-align: center;
    }

    .post-title {
      font-size: 2rem;
      font-weight: bold;
      margin-bottom: 1rem;
      color: #1a1a1a;
      line-height: 1.3;
    }

    .post-meta {
      color: #666;
      font-size: 0.9rem;
    }

    .post-meta .category {
      color: #4a75b5;
    }

    .post-content {
      font-size: 1.1rem;
      line-height: 1.8;
      color: #333;
    }

    .post-content :global(p) {
      margin-bottom: 1.5rem;
    }

    .post-content :global(h2) {
      font-size: 1.5rem;
      font-weight: bold;
      margin: 2.5rem 0 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #eee;
    }

    .post-content :global(h3) {
      font-size: 1.25rem;
      font-weight: bold;
      margin: 2rem 0 0.75rem;
      color: #222;
    }

    .post-content :global(a) {
      color: #4a75b5;
      text-decoration: none;
    }

    .post-content :global(a:hover) {
      text-decoration: underline;
    }

    .post-content :global(code) {
      background: #f5f5f5;
      border: 1px solid #e0e0e0;
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
      font-family: 'Courier New', monospace;
      font-size: 0.9em;
    }

    .post-content :global(pre) {
      background: #f7f7f7;
      border: 1px solid #e0e0e0;
      border-radius: 4px;
      padding: 1rem;
      overflow-x: auto;
      margin: 1.5rem 0;
    }

    .post-content :global(pre code) {
      background: none;
      border: none;
      padding: 0;
    }

    .post-content :global(ul),
    .post-content :global(ol) {
      margin: 1rem 0 1rem 1.5rem;
    }

    .post-content :global(li) {
      margin-bottom: 0.5rem;
    }

    .post-content :global(blockquote) {
      margin: 1.5rem 0;
      padding: 0.5rem 0 0.5rem 1rem;
      border-left: 4px solid #4a75b5;
      color: #666;
    }

    .post-content :global(img) {
      max-width: 100%;
      height: auto;
      display: block;
      margin: 1.5rem auto;
    }
  </style>
</BaseLayout>
