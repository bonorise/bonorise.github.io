---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

// 按日期排序
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 分类名称映射
const categoryNames = {
  'front': '前哨·王煜全',
  'methodology': '谷歌方法论·吴军',
  'elite-lessons': '精英日课·万维钢',
  'wealth-freedom': '通往财富自由之路·李笑来',
  'daydayup': '日知录·吴伯凡',
  'js': '零基础看段子学 JS',
  'blog': '博客随笔',
};
---

<BaseLayout
  title="波波的分享"
  description="养成每天写作的好习惯，把自己学习的思考的内容写下来"
>
  <div class="home">
    <!-- 顶部导航条 -->
    <header class="site-header fade-in">
      <div class="header-inner">
        <div class="site-branding">
          <span class="site-title">波波的分享</span>
        </div>
        <!-- 分类导航 -->
        <nav class="category-nav">
          <ul class="category-list">
            {Object.entries(categoryNames).map(([slug, name]) => (
              <li>
                <a href={`/categories/${slug}/`}>{name}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <!-- 文章列表 -->
    <main class="content">
      <ul class="article-list">
        {posts.map((post, index) => (
          <li class={`article-card fade-in delay-${index % 6}`}>
            <a href={`/posts/${post.id}/`} class="article-card-link">
              <article class="article-card-content">
                <h3 class="article-title">{post.data.title}</h3>
                {post.data.description && (
                  <p class="article-description">{post.data.description}</p>
                )}
                <div class="article-meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('zh-CN', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                </div>
              </article>
            </a>
          </li>
        ))}
      </ul>
    </main>

    <!-- 页脚 -->
    <footer class="site-footer">
      <p>© {new Date().getFullYear()} liubo.im · 用写作思考</p>
    </footer>
  </div>

  <style>
    .home {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ===== Site Header ===== */
    .site-header {
      background: var(--color-bg-card);
      border-bottom: 1px solid var(--color-border-light);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: var(--space-sm) var(--space-lg);
      display: flex;
      align-items: center;
      gap: var(--space-xl);
    }

    .site-branding .site-title {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--color-text);
      white-space: nowrap;
    }

    /* ===== Category Navigation ===== */
    .category-nav {
      flex: 1;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .category-list {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      list-style: none;
      padding: 0;
      margin: 0;
      white-space: nowrap;
    }

    .category-list a {
      color: var(--color-text-light);
      font-size: 0.875rem;
      text-decoration: none;
      transition: color var(--transition-fast);
    }

    .category-list a:hover {
      color: var(--color-primary);
    }

    /* ===== Main Content ===== */
    .content {
      flex: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: var(--space-2xl) var(--space-lg);
      width: 100%;
    }

    .article-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-lg);
    }

    .article-card {
      margin: 0;
    }

    .article-card-link {
      display: block;
      text-decoration: none;
      color: inherit;
    }

    .article-card-content {
      background: var(--color-bg-card);
      padding: var(--space-lg);
      border-radius: var(--radius-sm);
      border: 1px solid var(--color-border-light);
      box-shadow: var(--shadow-sm);
      transition: all var(--transition-base);
    }

    .article-card:hover .article-card-content {
      box-shadow: var(--shadow-lg);
      transform: translateY(-3px);
      border-color: var(--color-border);
    }

    .article-title {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--color-text);
      margin: 0 0 var(--space-sm) 0;
      line-height: 1.4;
    }

    .article-card:hover .article-title {
      color: var(--color-primary);
    }

    .article-description {
      color: var(--color-text-light);
      font-size: 0.9375rem;
      line-height: 1.6;
      margin: 0 0 var(--space-md) 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .article-meta {
      display: flex;
      align-items: center;
      gap: var(--space-md);
    }

    .article-meta time {
      font-size: 0.8125rem;
      color: var(--color-text-muted);
      font-weight: 500;
    }

    /* ===== Footer ===== */
    .site-footer {
      background: var(--color-bg-card);
      border-top: 1px solid var(--color-border-light);
      padding: var(--space-xl) var(--space-lg);
      text-align: center;
    }

    .site-footer p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: 0.875rem;
    }

    /* ===== 响应式 ===== */
    @media (max-width: 768px) {
      .header-inner {
        flex-direction: column;
        gap: var(--space-sm);
        align-items: flex-start;
      }

      .site-branding .site-title {
        font-size: 1rem;
      }

      .category-nav {
        width: 100%;
      }

      .category-list {
        gap: var(--space-sm);
      }

      .category-list a {
        font-size: 0.8125rem;
      }

      .content {
        padding: var(--space-lg);
      }

      .article-card-content {
        padding: var(--space-md);
      }

      .article-title {
        font-size: 1.125rem;
      }
    }
  </style>
</BaseLayout>
