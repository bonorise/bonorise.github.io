---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  // 收集所有分类
  const categories = new Set<string>();
  for (const post of posts) {
    if (post.data.category) {
      categories.add(post.data.category);
    }
  }

  // 生成每个分类的路径
  return Array.from(categories).map(category => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.params;

// 获取所有文章并过滤
const allPosts = await getCollection('blog');
const categoryPosts = allPosts.filter(post => post.data.category === category);

// 按日期排序
categoryPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 分类名称映射
const categoryNames = {
  'front': '《前哨·王煜全》笔记',
  'methodology': '《谷歌方法论·吴军》笔记',
  'elite-lessons': '《精英日课·万维钢》笔记',
  'wealth-freedom': '《通往财富自由之路·李笑来》笔记',
  'daydayup': '《日知录·吴伯凡》笔记',
  'js': '零基础看段子学 JS',
  'blog': '博客随笔',
};

// 分类描述
const categoryDescriptions = {
  'front': '关注科技前沿、产业趋势和创新机会',
  'methodology': '学习科学研究方法、思维模式和认知升级',
  'elite-lessons': '跨学科知识精讲，涵盖经济、心理、生物等领域',
  'wealth-freedom': '关于财富、投资和个人成长的思考',
  'daydayup': '日常思考和认知升级的点滴记录',
  'js': '用轻松的方式学习 JavaScript 编程',
  'blog': '生活随笔、个人感悟和其他内容',
};

const categoryName = (category && categoryNames[category]) || category || '分类';
const categoryDescription = (category && categoryDescriptions[category]) || '';

const articleCount = categoryPosts.length;
---

<BaseLayout
  title={categoryName}
  description={`${categoryDescription} · 共 ${articleCount} 篇文章`}
>
  <div class="category-page">
    <!-- 分类头部 -->
    <header class="category-header fade-in">
      <!-- 面包屑导航 -->
      <nav class="breadcrumb">
        <a href="/" class="breadcrumb-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          首页
        </a>
        <span class="breadcrumb-separator">/</span>
        <span class="breadcrumb-current">{categoryName}</span>
      </nav>

      <!-- 分类标题 -->
      <div class="category-info">
        <h1 class="category-title">{categoryName}</h1>
        {categoryDescription && (
          <p class="category-description">{categoryDescription}</p>
        )}
        <div class="category-meta">
          <span class="article-count">{articleCount} 篇文章</span>
        </div>
      </div>
    </header>

    <!-- 文章列表 -->
    <main class="category-content">
      {categoryPosts.length > 0 ? (
        <ul class="article-list">
          {categoryPosts.map((post, index) => (
            <li class={`article-card fade-in delay-${index % 6}`}>
              <a href={`/posts/${post.id}/`} class="article-card-link">
                <article class="article-card-content">
                  <h3 class="article-title">{post.data.title}</h3>
                  {post.data.description && (
                    <p class="article-description">{post.data.description}</p>
                  )}
                  <div class="article-meta">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('zh-CN', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </time>
                  </div>
                </article>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="empty-state">
          <div class="empty-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="12" y1="18" x2="12" y2="12"/>
              <line x1="9" y1="15" x2="15" y2="15"/>
            </svg>
          </div>
          <h3>还没有文章</h3>
          <p>这个分类下还没有内容，敬请期待</p>
          <a href="/" class="back-home-link">返回首页</a>
        </div>
      )}
    </main>

    <!-- 页脚 -->
    <footer class="category-footer">
      <a href="/" class="back-to-home">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        返回首页
      </a>
    </footer>
  </div>

  <style>
    .category-page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ===== Category Header ===== */
    .category-header {
      background: var(--color-bg-card);
      border-bottom: 1px solid var(--color-border-light);
      padding: var(--space-xl) var(--space-lg);
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
      margin-bottom: var(--space-lg);
      font-size: 0.875rem;
    }

    .breadcrumb-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      color: var(--color-text-muted);
      transition: color var(--transition-fast);
    }

    .breadcrumb-link:hover {
      color: var(--color-primary);
    }

    .breadcrumb-separator {
      color: var(--color-border);
    }

    .breadcrumb-current {
      color: var(--color-text-light);
      font-weight: 500;
    }

    .category-info {
      max-width: 720px;
    }

    .category-title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--color-text);
      margin-bottom: var(--space-sm);
      letter-spacing: -0.02em;
    }

    .category-description {
      color: var(--color-text-light);
      font-size: 1rem;
      margin-bottom: var(--space-md);
    }

    .category-meta {
      display: flex;
      align-items: center;
      gap: var(--space-md);
    }

    .article-count {
      display: inline-block;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-primary);
      background: rgba(45, 90, 74, 0.08);
      padding: 0.375rem 0.75rem;
      border-radius: 99px;
    }

    /* ===== Category Content ===== */
    .category-content {
      flex: 1;
      max-width: 800px;
      margin: 0 auto;
      padding: var(--space-2xl) var(--space-lg);
      width: 100%;
    }

    .article-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-lg);
    }

    .article-card {
      margin: 0;
    }

    .article-card-link {
      display: block;
      text-decoration: none;
      color: inherit;
    }

    .article-card-content {
      background: var(--color-bg-card);
      padding: var(--space-lg);
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-border-light);
      box-shadow: var(--shadow-sm);
      transition: all var(--transition-base);
    }

    .article-card:hover .article-card-content {
      box-shadow: var(--shadow-lg);
      transform: translateY(-3px);
      border-color: var(--color-border);
    }

    .article-title {
      font-size: 1.1875rem;
      font-weight: 600;
      color: var(--color-text);
      margin: 0 0 var(--space-sm) 0;
      line-height: 1.4;
    }

    .article-card:hover .article-title {
      color: var(--color-primary);
    }

    .article-description {
      color: var(--color-text-light);
      font-size: 0.9375rem;
      line-height: 1.6;
      margin: 0 0 var(--space-md) 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .article-meta time {
      font-size: 0.8125rem;
      color: var(--color-text-muted);
      font-weight: 500;
    }

    /* ===== Empty State ===== */
    .empty-state {
      text-align: center;
      padding: var(--space-2xl) var(--space-lg);
    }

    .empty-icon {
      color: var(--color-border);
      margin-bottom: var(--space-lg);
    }

    .empty-state h3 {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--color-text);
      margin-bottom: var(--space-xs);
    }

    .empty-state p {
      color: var(--color-text-muted);
      margin-bottom: var(--space-lg);
    }

    .back-home-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      color: var(--color-primary);
      font-weight: 500;
      padding: var(--space-sm) var(--space-md);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      transition: all var(--transition-base);
    }

    .back-home-link:hover {
      background: var(--color-primary);
      color: white;
      border-color: var(--color-primary);
    }

    /* ===== Category Footer ===== */
    .category-footer {
      background: var(--color-bg-card);
      border-top: 1px solid var(--color-border-light);
      padding: var(--space-xl) var(--space-lg);
      text-align: center;
    }

    .back-to-home {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      color: var(--color-text-muted);
      font-size: 0.9375rem;
      font-weight: 500;
      padding: var(--space-sm) var(--space-md);
      border-radius: var(--radius-sm);
      transition: all var(--transition-base);
    }

    .back-to-home:hover {
      color: var(--color-primary);
      background: var(--color-bg);
    }

    .back-to-home svg {
      transition: transform var(--transition-fast);
    }

    .back-to-home:hover svg {
      transform: translateX(-3px);
    }

    /* ===== 响应式 ===== */
    @media (max-width: 768px) {
      .category-title {
        font-size: 1.5rem;
      }

      .category-header {
        padding: var(--space-lg);
      }

      .category-content {
        padding: var(--space-lg);
      }

      .article-card-content {
        padding: var(--space-md);
      }

      .article-title {
        font-size: 1.0625rem;
      }
    }
  </style>
</BaseLayout>
